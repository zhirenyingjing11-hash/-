# ローカルの Ollama サーバー設定（このファイルを .env.local にコピーして使用）

# Ollama の API エンドポイント（既定: http://localhost:11434）
OLLAMA_HOST=http://localhost:11434

# 使用する画像対応(vision)モデル。事前に `ollama pull <model>` が必要。
# 既定: qwen2.5vl:7b（中程度PC向け・チャート/OCRに強い）
# 軽量PC: moondream / llava:7b   高性能PC: llama3.2-vision:11b / qwen2.5vl:32b
OLLAMA_MODEL=qwen2.5vl:7b
